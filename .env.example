# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Application Configuration
NODE_ENV=production
NEXT_PUBLIC_APP_URL=live_site_url_here

# Local development fallback:
# If NEXT_PUBLIC_APP_URL is not set, the app will fall back to http://localhost:3000

# Optional: Rate Limiting Configuration (defaults shown)
# RATE_LIMIT_REQUESTS=5
# RATE_LIMIT_WINDOW_MS=60000

# Optional: Logging (for production monitoring)
# LOG_LEVEL=info
